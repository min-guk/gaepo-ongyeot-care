{
  "name": "gaepo-ongyeot-care",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.9 <21"
  },
  "scripts": {
    "dev": "next dev",
    "prebuild": "node scripts/validate-production-facts.mjs",
    "build": "next build",
    "build:production": "node scripts/validate-production-facts.mjs --mode=production && next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit tests/integration",
    "facts:validate": "node scripts/validate-production-facts.mjs",
    "facts:validate:production": "node scripts/validate-production-facts.mjs --mode=production"
  },
  "dependencies": {
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "9.39.5",
    "@types/node": "20.19.24",
    "@types/react": "19.2.9",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.46.2",
    "@typescript-eslint/parser": "8.46.2",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "typescript": "5.9.3",
    "vitest": "3.2.7"
  },
  "overrides": {
    "postcss": "8.5.21"
  }
}
