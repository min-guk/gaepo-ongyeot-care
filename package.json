{
  "name": "gaepo-ongyeot-care",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.9 <21"
  },
  "scripts": {
    "dev": "next dev",
    "prebuild": "node scripts/validate-production-facts.mjs",
    "build": "next build",
    "build:production": "node scripts/validate-production-facts.mjs --mode=production && next build",
    "preview": "npm run facts:validate && opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "npm run facts:validate && opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit tests/integration",
    "facts:validate": "node scripts/validate-production-facts.mjs",
    "facts:validate:production": "node scripts/validate-production-facts.mjs --mode=production"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "1.20.2",
    "next": "16.2.11",
    "rclone.js": "0.6.6",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "9.39.5",
    "@types/node": "20.19.24",
    "@types/react": "19.2.9",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.46.2",
    "@typescript-eslint/parser": "8.46.2",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.11",
    "typescript": "5.9.3",
    "vitest": "3.2.7",
    "wrangler": "4.86.0"
  },
  "overrides": {
    "adm-zip": "0.6.0",
    "esbuild": "0.28.1",
    "postcss": "8.5.21",
    "sharp": "0.35.3",
    "undici": "7.28.0",
    "ws": "8.21.1"
  }
}
