{
  "name": "gaepo-ongyeot-care",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.3 <21"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "typecheck": "astro check && tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit tests/integration",
    "test:workerd": "node scripts/workerd-smoke.mjs",
    "preview:worker": "wrangler dev",
    "dry-run": "wrangler deploy --dry-run"
  },
  "dependencies": {
    "@astrojs/cloudflare": "12.6.13",
    "astro": "5.18.2"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.6",
    "@cloudflare/workers-types": "4.20260702.1",
    "@eslint/js": "9.39.5",
    "@types/node": "20.19.24",
    "@typescript-eslint/eslint-plugin": "8.46.2",
    "@typescript-eslint/parser": "8.46.2",
    "eslint": "9.39.5",
    "typescript": "5.9.3",
    "vitest": "3.2.7",
    "wrangler": "4.86.0"
  }
}
