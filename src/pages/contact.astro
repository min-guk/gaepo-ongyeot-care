---
export const prerender = true;
const siteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY;
const onlineEnabled = siteKey && !siteKey.startsWith("__REQUIRED_");
---
<!doctype html>
<html lang="ko"><head><meta charset="UTF-8" /><meta name="viewport" content="width=device-width" /><title>돌봄 문의 — 개포 온곁</title></head>
<body><main><h1>돌봄 문의</h1><p>진단명, 건강 상태, 주민등록번호, 상세 주소는 입력하지 마세요.</p>
<form method="post" action="/api/inquiries/care" accept-charset="UTF-8">
<label>이름 <input name="name" autocomplete="name" maxlength="30" required /></label>
<label>전화번호 <input name="phone" type="tel" autocomplete="tel" inputmode="tel" required /></label>
<label>연락 희망 시간 <select name="preferredContactTime" required><option value="">선택</option><option value="anytime">언제든지</option><option value="morning">오전</option><option value="afternoon">오후</option><option value="evening">저녁</option></select></label>
<label>대략적인 지역 <select name="coarseArea" required><option value="">선택</option><option value="gaepo">개포동</option><option value="daechi">대치동</option><option value="dogok">도곡동</option><option value="irwon">일원동</option><option value="suseo">수서동</option><option value="other-gangnam">강남구 기타</option></select></label>
<label>상담 주제 <select name="topic" required><option value="">선택</option><option value="visit-care">방문요양</option><option value="family-care">가족요양</option><option value="visit-bathing">방문목욕</option><option value="long-term-care-grade">장기요양등급</option><option value="other-basic">기본 상담</option></select></label>
<label><input type="checkbox" name="privacyConsent" value="accepted" required /> 개인정보 안내를 확인했고 문의 전달에 동의합니다.</label>
<label hidden aria-hidden="true">웹사이트 <input name="website" tabindex="-1" autocomplete="off" /></label>
{onlineEnabled ? <div class="cf-turnstile" data-sitekey={siteKey}></div> : <p role="note">온라인 문의는 운영 키 설정 후 활성화됩니다.</p>}
<button type="submit">문의 보내기</button></form>
<section id="alternatives" aria-labelledby="alternative-title"><h2 id="alternative-title">다른 문의 방법</h2><p>온라인 접수가 어렵다면 운영 정보가 확정된 뒤 제공되는 전화 또는 카카오톡 상담을 이용해 주세요.</p></section></main>
{onlineEnabled && <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>}</body></html>
